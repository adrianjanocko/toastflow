{
  "name": "vue-toastflow-playground",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^24.11.1"
  },
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev": "vite",
    "prebuild": "pnpm --filter toastflow-core build && pnpm --filter vue-toastflow build",
    "build": "run-s generate:sitemap type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "generate:sitemap": "node ./scripts/generate-sitemap.cjs",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix --cache",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@giscus/vue": "^3.1.1",
    "@highlightjs/vue-plugin": "^2.1.0",
    "@tailwindcss/vite": "^4.2.2",
    "highlight.js": "^11.11.1",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.2.2",
    "toastflow-core": "workspace:^",
    "vue": "^3.5.27",
    "vue-snowfall": "^1.1.8",
    "vue-toastflow": "workspace:^"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.5",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/eslint-plugin": "^1.6.16",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.1",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.2",
    "npm-run-all2": "^8.0.4",
    "prettier": "3.8.3",
    "typescript": "~6.0.3",
    "vite": "^8.0.8",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.2.6"
  }
}
