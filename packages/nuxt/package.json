{
  "name": "nuxt-toastflow",
  "author": "adrianjanocko",
  "description": "Nuxt module for Toastflow — accessible, customizable toast notifications with auto-imports, SSR support, and CSS-first theming.",
  "keywords": [
    "nuxt",
    "nuxt-module",
    "toast",
    "toastflow",
    "notifications",
    "notification",
    "toast-notifications",
    "toaster",
    "vue",
    "typescript"
  ],
  "license": "MIT",
  "homepage": "https://toastflow.top/",
  "repository": {
    "type": "git",
    "url": "https://github.com/adrianjanocko/toastflow.git",
    "directory": "packages/nuxt"
  },
  "version": "1.0.1",
  "main": "./dist/module.js",
  "module": "./dist/module.mjs",
  "types": "./dist/module.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/module.d.mts",
        "default": "./dist/module.mjs"
      },
      "require": {
        "types": "./dist/module.d.ts",
        "default": "./dist/module.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/module.ts --format cjs,esm && tsc --emitDeclarationOnly && node -e \"require('fs').copyFileSync('dist/module.d.ts','dist/module.d.mts')\"",
    "prepack": "pnpm run build"
  },
  "peerDependencies": {
    "nuxt": "^3.0.0 || ^4.0.0"
  },
  "dependencies": {
    "@nuxt/kit": "^4.4.2",
    "vue-toastflow": "workspace:^"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
